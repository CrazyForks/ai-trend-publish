# =============================================================================
# TrendPublish 环境变量示例
#
# 使用方式：
# 1. cp .env.example .env
# 2. 先填 [A] 最小必填配置
# 3. 再按需要开启 [B] 到 [H] 的功能块
# 4. 运行 deno task doctor 检查当前启用功能缺哪些配置
# =============================================================================

# -----------------------------------------------------------------------------
# [A] 最小必填配置：启动服务、模板预览、AI 摘要/排序/动态模板都依赖这些
# -----------------------------------------------------------------------------

# JSON-RPC API 鉴权 token。请求接口时使用 Authorization: Bearer <SERVER_API_KEY>
SERVER_API_KEY="change-me"

# 全项目默认只使用这一套模型配置，要求接口兼容 OpenAI Chat Completions。
# 示例：
# - OpenAI:   LLM_BASE_URL="https://api.openai.com/v1"                         LLM_MODEL="gpt-4o-mini"
# - DeepSeek: LLM_BASE_URL="https://api.deepseek.com/v1"                        LLM_MODEL="deepseek-chat"
# - Qwen:     LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"  LLM_MODEL="qwen-max"
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_API_KEY="your_api_key"
LLM_MODEL="deepseek-chat"

# 微信公众号发布配置。
# - deno task preview 不需要
# - deno task article:dry 默认不发布，但完整链路/正式发布建议配置
# - deno task article 正式发布必须配置
WEIXIN_APP_ID="your_app_id"
WEIXIN_APP_SECRET="your_app_secret"

# -----------------------------------------------------------------------------
# [B] 微信文章工作流：文章数量、模板、dry-run
# -----------------------------------------------------------------------------

# 微信文章模板类型：
# default | modern | tech | mianpro | longform | product | minimal | darktech | dynamic | random
ARTICLE_TEMPLATE_TYPE="minimal"

# 本地调试开关。true 时跳过公众号 IP 白名单、封面上传、正文图片上传和正式发布。
DRY_RUN=false

# 每次文章工作流选取的文章数量
ARTICLE_NUM=10

# 微信文章元信息
AUTHOR="your_name"
NEED_OPEN_COMMENT=false
ONLY_FANS_CAN_COMMENT=false

# -----------------------------------------------------------------------------
# [C] 抓取源：至少配置一种，文章工作流才有内容来源
# -----------------------------------------------------------------------------

# FireCrawl 网页抓取：https://www.firecrawl.dev/
FIRE_CRAWL_API_KEY=""

# Twitter/X 抓取：https://twitterapi.io/
X_API_BEARER_TOKEN=""

# Xquik 备用 Twitter/X 抓取源：https://xquik.com/
XQUIK_API_KEY=""

# Jina Reader / DeepSearch / Embedding / Reranker：https://jina.ai/?sui=apikey
JINA_API_KEY=""

# -----------------------------------------------------------------------------
# [D] 封面生图：可选。未配置或生成失败时会使用兜底封面
# -----------------------------------------------------------------------------

# 阿里云百炼 / DashScope 通义万相
DASHSCOPE_API_KEY=""

# -----------------------------------------------------------------------------
# [E] 去重：可选。开启后需要 Embedding 配置和数据库
# -----------------------------------------------------------------------------

ENABLE_DEDUPLICATION=false

# 当前文章去重默认使用 DashScope text-embedding-v3
DASHSCOPE_EMBEDDING_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_EMBEDDING_API_KEY=""
DASHSCOPE_EMBEDDING_MODEL="text-embedding-v3"

# -----------------------------------------------------------------------------
# [F] 数据库存储：可选。用于数据库数据源配置和向量去重数据
# -----------------------------------------------------------------------------

ENABLE_DB=false
DB_HOST="localhost"
DB_PORT=3306
DB_USER="root"
DB_PASSWORD="password"
DB_DATABASE="trendfinder"

# -----------------------------------------------------------------------------
# [G] 通知：可选。开启哪个通知，就必须配置对应 webhook/key
# -----------------------------------------------------------------------------

ENABLE_BARK=false
BARK_URL=""

ENABLE_DINGDING=false
DINGDING_WEBHOOK=""

ENABLE_FEISHU=false
FEISHU_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# [H] 定时任务：每天凌晨 3 点按星期选择工作流
# -----------------------------------------------------------------------------

1_of_week_workflow=weixin-article-workflow
2_of_week_workflow=weixin-aibench-workflow
3_of_week_workflow=weixin-hellogithub-workflow
4_of_week_workflow=weixin-article-workflow
5_of_week_workflow=weixin-article-workflow
6_of_week_workflow=weixin-article-workflow
7_of_week_workflow=weixin-article-workflow

# HelloGitHub 模板类型：default | random
HELLOGITHUB_TEMPLATE_TYPE="default"

# AIBench 模板类型：default | random
AIBENCH_TEMPLATE_TYPE="default"
